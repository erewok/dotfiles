# ============================================================================
# Personal ZSH Configuration
# Sourced by Home Manager after Nix-managed setup (Pure, kube-ps1, direnv, etc.)
# ============================================================================

# --- Common config (shared with work) ---
[[ -f "$HOME/open_source/dotfiles/shell/common-zshrc" ]] && source "$HOME/open_source/dotfiles/shell/common-zshrc"

# --- Load dotfiles aliases ---
[[ -f "$HOME/open_source/dotfiles/shell/aliases" ]] && source "$HOME/open_source/dotfiles/shell/aliases"

# --- Load personal aliases ---
[[ -f "$HOME/open_source/dotfiles/shell/home-aliases" ]] && source "$HOME/open_source/dotfiles/shell/home-aliases"

# --- GhcUP (Haskell) ---
[[ -f "$HOME/.ghcup/env" ]] && source "$HOME/.ghcup/env"
